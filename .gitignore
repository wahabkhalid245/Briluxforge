# =============================================================================
# Briluxforge — .gitignore
# Scope: Flutter desktop (Windows / macOS / Linux), Riverpod code-gen, Drift/SQLite
# =============================================================================

# -----------------------------------------------------------------------------
# Flutter / Dart tooling
# -----------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# pubspec.lock is intentionally committed for reproducible builds.
# pubspec.lock

# -----------------------------------------------------------------------------
# Code-generated files (Riverpod generator, Drift, json_serializable)
# These are always regenerated by:
#   dart run build_runner build --delete-conflicting-outputs
# Never commit generated files — the source annotations are the truth.
# -----------------------------------------------------------------------------
*.g.dart
*.freezed.dart
*.mocks.dart

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
build/

# Obfuscation debug symbols (MUST NOT ship — Section 7.4 of CLAUDE.md)
build/debug-info/

# -----------------------------------------------------------------------------
# Platform — Windows
# Flutter injects ephemeral files at build time; never commit these.
# -----------------------------------------------------------------------------
windows/flutter/ephemeral/
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake
windows/flutter/generated_config.cmake

# MSVC / Ninja build artefacts (appear under build/ but be explicit)
*.obj
*.pdb
*.ilk
*.exp
*.lib

# -----------------------------------------------------------------------------
# Platform — macOS
# -----------------------------------------------------------------------------
macos/Flutter/ephemeral/
macos/Flutter/Flutter-Generated.xcconfig
macos/Flutter/flutter_export_environment.sh

# Xcode local caches
macos/Pods/
**/DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/

# CocoaPods (not used in this project, but guard against accidental init)
Podfile.lock

# Xcode build products (archives, debug symbols, distribution artifacts)
*.xcarchive
*.dSYM/
*.dmg
*.pkg

# Distribution output directory (Windows .zip, macOS .dmg, Linux AppImage)
dist/

# -----------------------------------------------------------------------------
# Platform — Linux
# -----------------------------------------------------------------------------
linux/flutter/ephemeral/
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake

# -----------------------------------------------------------------------------
# IDE — JetBrains (IntelliJ / Android Studio)
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws

# -----------------------------------------------------------------------------
# IDE — VS Code
# -----------------------------------------------------------------------------
.vscode/

# -----------------------------------------------------------------------------
# OS cruft
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptedDatabase
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Local databases (Drift / SQLite)
# Drift stores the live database in the user's AppData / home directory,
# not the project root — but guard against any test or dev databases that
# could appear here (e.g. from integration tests run in the repo directory).
# -----------------------------------------------------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Secure storage artefacts
# flutter_secure_storage delegates to OS APIs (Credential Manager, Keychain,
# libsecret) so no key files land in the repo — but guard against any
# local development workarounds that write key files.
# -----------------------------------------------------------------------------
*.keystore
*.jks
*.p12
*.pfx
*.pem
*.key
*.cer

# -----------------------------------------------------------------------------
# Environment / secrets
# Never commit plaintext secrets or .env files.
# -----------------------------------------------------------------------------
.env
.env.*
*.env
secrets.json
secrets.yaml
secrets.yml

# -----------------------------------------------------------------------------
# Firebase
# firebase_options.dart is committed (project config, no secrets).
# firebase.json contains project registration IDs — do not commit.
# The service-account JSON must NEVER be committed.
# -----------------------------------------------------------------------------
firebase.json
*service-account*.json
google-services.json
GoogleService-Info.plist
.firebaserc

# -----------------------------------------------------------------------------
# Gumroad / licensing
# Never commit license keys or purchase receipts used during local testing.
# -----------------------------------------------------------------------------
*.license
gumroad_test_keys.txt

# -----------------------------------------------------------------------------
# Claude / AI session files that may contain sensitive project context
# -----------------------------------------------------------------------------
.claude/settings.local.json

# -----------------------------------------------------------------------------
# Logs & crash dumps
# -----------------------------------------------------------------------------
*.log
*.log.*
*.dmp
*.crash

# -----------------------------------------------------------------------------
# Dart / Pub cache (if accidentally initialised inside the project)
# -----------------------------------------------------------------------------
.pub-cache/
.pub/

# -----------------------------------------------------------------------------
# Test artefacts
# -----------------------------------------------------------------------------
coverage/
test/.test_coverage.dart
lcov.info
